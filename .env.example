# Dentist Website - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Admin Panel Password
# ===========================================
# This is the password to access the admin dashboard
# CHANGE THIS to a secure password before deploying!
ADMIN_PASSWORD=your-secure-password-here

# ===========================================
# REQUIRED - Database Configuration
# ===========================================
# SQLite database file path (default is fine for most cases)
DATABASE_URL=file:./db/custom.db

# ===========================================
# OPTIONAL - Customization
# ===========================================
# You can customize these in the code if needed:
# - Doctor's name: Edit src/app/page.tsx
# - Services offered: Edit src/app/page.tsx
# - Contact information: Edit src/app/page.tsx
# - Office hours: Edit src/app/page.tsx
